{
  "name": "telegram-admin-bot",
  "version": "1.0.0",
  "description": "Telegram бот для управления товарами с QR-кодами",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "rm -rf dist && tsc && mkdir -p dist/assets/fonts && cp src/assets/fonts/*.ttf dist/assets/fonts/",
    "start": "node dist/main.js",
    "pm2": "npm run build && pm2 restart main --update-env",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "telegram",
    "grammy",
    "typescript",
    "qrcode",
    "bot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "axios": "^1.13.5",
    "canvas": "^3.2.1",
    "dotenv": "^16.3.1",
    "grammy": "^1.24.0",
    "jimp": "^1.6.0",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import-x": "^4.16.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0"
  }
}
